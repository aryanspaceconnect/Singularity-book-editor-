rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isProjectOwner(projectId) {
      // Allow if the user is the owner of the project
      return isAuthenticated() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /vault_files/{fileId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /agents/{agentId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /projects/{projectId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      
      match /messages/{messageId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /logs/{logId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /agents/{agentId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /canvas/{docId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /versions/{versionId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /files/{fileId} {
        allow read, write: if isProjectOwner(projectId);
      }
      
      match /blocks/{blockId} {
        allow read, write: if isProjectOwner(projectId);
      }
    }
  }
}
